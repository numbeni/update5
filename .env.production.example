# ─────────────────────────────────────────────────────────────────────────────
# NOC Monitor — Production environment variables
# Copy to .env.production and fill in all values marked with ← REQUIRED
#   cp .env.production.example .env.production
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (used by docker-compose) ──────────────────────────────────────
POSTGRES_DB=noc_monitor
POSTGRES_USER=noc
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD        # ← REQUIRED

# ── App ───────────────────────────────────────────────────────────────────────
# Port exposed on the host machine (nginx proxies this)
APP_PORT=5000

# Restrict API to your domain only (recommended in production)
# ALLOWED_ORIGINS=https://noc.yourdomain.com        # ← RECOMMENDED

# ── Optional: Nextcloud Talk alerts ──────────────────────────────────────────
# NEXTCLOUD_TALK_URL=https://nextcloud.yourdomain.com
# NEXTCLOUD_TALK_USER=alertbot
# NEXTCLOUD_TALK_PASSWORD=secret
# NEXTCLOUD_TALK_ROOM=roomtoken1,roomtoken2

# ── Optional: Telegram alerts ─────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=123456789:ABC-xyz
# TELEGRAM_CHAT_ID=-100123456789

# ── Optional: custom connectivity sentinel targets ────────────────────────────
# CONNECTIVITY_TARGETS=Google:google.com,Soft98:soft98.ir,Varzesh3:www.varzesh3.com
